# Required only when using --backend agent-sdk.
# Uses the Anthropic API with per-token billing.
# Not needed for --backend claude-cli (default, uses Max/Pro subscription).
# ANTHROPIC_API_KEY=sk-ant-api03-PK1...fwAA

# Set to true to enable verbose file logging
VERBOSE_LOGGING=true

# Email configuration (used by `cestdone send-email`)
# MAIL_PROVIDER=smtp
# MAIL_FROM=you@example.com
# SMTP_HOST=smtp.zoho.com
# SMTP_PORT=587
# SMTP_USER=you@example.com
# SMTP_PASS=your-app-password
# SMTP_SECURE=false
