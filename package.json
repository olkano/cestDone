{
  "name": "cestdone",
  "version": "0.1.0",
  "description": "AI-orchestrated development & automation CLI",
  "type": "module",
  "main": "dist/cli/index.js",
  "bin": {
    "cestdone": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node --env-file=.env dist/cli/index.js",
    "dev": "tsx --env-file=.env src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "cli",
    "automation",
    "claude"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.41",
    "commander": "^13.0.0",
    "pino": "^9.6.0",
    "pino-roll": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
